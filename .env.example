# ============================================================
# AHost.uz Shared Hosting — Environment Variables
# ============================================================
# Bu faylni .env ga ko'chiring va qiymatlarni to'ldiring.
# HECH QACHON .env faylini git'ga push qilmang!
#
# Fayl joylashuvi: /home/username/zarifsblog/.env
# (Django loyiha papkasi ichida)
# ============================================================

# Django
SECRET_KEY=your-very-secret-random-key-here-change-me
DEBUG=False
ALLOWED_HOSTS=yourdomain.uz,www.yourdomain.uz

# Database (AHost cPanel -> MySQL Databases orqali yarating)
DB_ENGINE=django.db.backends.mysql
DB_NAME=username_blogdb
DB_USER=username_bloguser
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=3306

# Agar SQLite ishlatmoqchi bo'lsangiz yuqoridagi DB_ larni o'chirib:
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=/home/username/zarifsblog/db.sqlite3

# Static va Media
STATIC_URL=/staticfiles/
STATIC_ROOT=/home/username/public_html/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/home/username/public_html/media

# CORS (frontend va backend bitta domenda — kerak emas)
# Agar alohida subdomen ishlatsa:
# CORS_ALLOWED_ORIGINS=https://yourdomain.uz

# Email (parol tiklash uchun)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.yourdomain.uz
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.uz
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.uz
